# Production environment (pre-prod, development APP_ENV).
#
# Copy to `.env.prod` on the VM and fill in real values:
#   cp .env.prod.example .env.prod
#   nano .env.prod
#
# `.env.prod` is gitignored. Never commit secrets.
# `openssl rand -base64 48` is the right tool for the *_SECRET keys.

# ---- App ----
# Kept on `development` per the pre-prod brief: dev OTP `1234` works,
# payments fully mocked, no real SMS sent, error responses include
# stack traces. Flip to `production` ONLY when you wire real SMS +
# payment gateway + observability. The CORS + cookie domains
# already point at the real subdomains below.
APP_ENV=development
LOG_LEVEL=INFO

# ---- Postgres ----
POSTGRES_USER=gympass
# Generate a real password — `openssl rand -base64 32`.
POSTGRES_PASSWORD=CHANGE_ME_PROD_DB_PASSWORD
POSTGRES_DB=gympass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- JWT ----
# Generate with: openssl rand -hex 48
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_SERVICE_TTL_SECONDS=300
JWT_ALGORITHM=HS256

# ---- SMS (mocked in dev mode — logged to stdout, not sent) ----
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=GymPass

# ---- Payments (fully mocked per the pre-prod brief) ----
PAYMENT_PROVIDER=mock
PAYMENT_MOCK_DELAY_MS=1500

# ---- OAuth (Google) ----
# Leave blank if not configured. Google sign-in in the mobile app
# and admin will short-circuit gracefully.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Domains ----
ADMIN_DOMAIN=admin.gym-pass.net
API_DOMAIN=api.gym-pass.net
PARTNER_DOMAIN=partner.gym-pass.net
WEBSITE_DOMAIN=gym-pass.net

# ---- CORS ----
# Comma-separated list of origins the backend will accept. Locked
# strictly to the four production hostnames so a request bouncing
# off Cloudflare to api.gym-pass.net but Origin: evil.com is
# rejected at the backend's CORSMiddleware.
ALLOWED_CORS_ORIGINS=https://gym-pass.net,https://www.gym-pass.net,https://admin.gym-pass.net,https://partner.gym-pass.net

# ---- Admin bootstrap ----
# First admin account, seeded by scripts/seed.py on `alembic upgrade
# head`. Change the password BEFORE running the deploy script.
ADMIN_BOOTSTRAP_EMAIL=admin@gym-pass.net
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_BOOTSTRAP_PASSWORD

# ---- NextAuth + service-token exchange ----
# Shared between admin + gym-partner. Generate with:
#   openssl rand -base64 48
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
# Shared HMAC secret the partner/admin Next.js apps sign envelopes
# with before exchanging for a service JWT. Generate the same way.
ADMIN_EXCHANGE_SECRET=CHANGE_ME_EXCHANGE_SECRET

# ---- Media URL prefix (served by FastAPI's /media route) ----
# Used by the partner/admin profile uploaders to build public URLs
# for gym logos + photos. Lives on the api subdomain.
MEDIA_URL_PREFIX=https://api.gym-pass.net/media
