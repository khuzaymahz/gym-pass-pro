# Celery beat scheduler runtime state (binary file regenerated on every boot)
backend/celerybeat-schedule

# === Pre-prod / production secrets ===
# Never committed. The .example variants in the repo are the only
# template anyone needs.
.env.prod
.env.production

# Cloudflare Origin Cert + private key (mounted into nginx at deploy
# time). Cert is technically public; key absolutely is not. Treating
# both as one secret avoids accidentally leaking the key by leaking
# the directory.
nginx/certs/*.pem
nginx/certs/*.key
nginx/certs/*.crt

# Mobile build outputs (large, regenerated by `scripts/build-apk.sh`).
mobile/dart_defines.prod.json
mobile/build/

# Marketing site's APK + checksum (~30-60 MB, regenerated by the
# build script). The download landing page references /downloads/
# but the .apk itself is built locally and SCPed up.
website/public/downloads/*.apk
website/public/downloads/*.sha256

# Deprecated marketing prototypes — superseded by `website/`. Kept on
# disk for reference but excluded from version control so the only
# canonical marketing surface is `website/`.
website-2/
marketing/
