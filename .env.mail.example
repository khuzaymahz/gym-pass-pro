# Mailu (self-hosted mail server) configuration.
#
# Copy to .env.mail at the repo root and edit; passed to compose with
# `--env-file .env.mail` alongside the regular .env / .env.staging.
# Every service in docker-compose.mail.yml reads this file directly
# via `env_file:` so you don't have to repeat values across services.
#
# Full reference: https://mailu.io/2.0/configuration.html

# ──────────────────────────────────────────────────────────────────
# Identity
# ──────────────────────────────────────────────────────────────────

# Base domain the server is responsible for. Mailboxes will be
# `<user>@${DOMAIN}` — e.g. `admin@gym-pass.net`. The MX record in
# DNS must point at HOSTNAMES below (NOT this base domain).
DOMAIN=gym-pass.net

# Fully-qualified hostname of the mail server. Must have:
#   1. An A record pointing at the VM's public IP (DNS-only in
#      Cloudflare — grey cloud, NOT proxied).
#   2. A matching reverse DNS (PTR) record on the VM's IP.
#   3. An MX record for ${DOMAIN} pointing at this name.
# Comma-separated if you want multiple aliases; the first is canonical.
HOSTNAMES=mail.gym-pass.net

# Default mailbox for system / abuse / postmaster aliases. Created
# automatically by Mailu admin on first boot.
POSTMASTER=admin

# Where the admin UI / webmail listens. Mailu's front container reads
# this to build redirect URLs. Should match the nginx vhost.
WEBSITE=https://mail.gym-pass.net

# ──────────────────────────────────────────────────────────────────
# Secrets
# ──────────────────────────────────────────────────────────────────

# Mailu uses this to sign session cookies and derive internal HMAC
# keys. Exactly 16 alphanumeric characters (Mailu's own validator
# rejects anything else). Generate with:
#   python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits) for _ in range(16)))"
# NEVER reuse the NEXTAUTH_SECRET / ADMIN_EXCHANGE_SECRET from the
# main .env — different blast radius.
SECRET_KEY=changemechangeme

# Initial admin account. Mailu's admin UI bootstraps `${INITIAL_ADMIN_ACCOUNT}@${DOMAIN}`
# with this password on first run; the variable is then ignored. After
# first login, change the password through the UI and unset both lines
# (they leave the bootstrap password on disk in the container env).
INITIAL_ADMIN_ACCOUNT=admin
INITIAL_ADMIN_PW=ChangeMeOnFirstLogin!
# `update` makes Mailu reset the admin password on every boot to the
# value above (useful while you're still iterating on the install);
# switch to `ifmissing` once you trust it.
INITIAL_ADMIN_MODE=ifmissing

# ──────────────────────────────────────────────────────────────────
# TLS
# ──────────────────────────────────────────────────────────────────

# `cert` = use the cert + key we bind-mount at /certs/cert.pem and
# /certs/key.pem. We mount the existing Cloudflare Origin Cert there,
# so this matches the rest of the stack. Other valid values are
# `letsencrypt` (Mailu fetches one itself — not what we want, Cloudflare
# already handles cert lifecycle), `notls` (dev only), `mail` (separate
# cert for mail only).
TLS_FLAVOR=cert

# ──────────────────────────────────────────────────────────────────
# Component toggles — keep the defaults unless you have a reason
# ──────────────────────────────────────────────────────────────────

# Enable the Mailu admin Flask UI (mail-admin service). Without this
# you can't generate new mailboxes through the web.
ADMIN=true

# Which webmail to ship. Roundcube is the lighter option and matches
# the docker-compose.mail.yml service we defined; `snappymail` and
# `none` are the other valid values. If you change this, also swap
# the mail-webmail service's image.
WEBMAIL=roundcube

# Enable Rspamd for spam scoring + DKIM signing on outbound.
ANTISPAM=true

# URL paths under which the admin UI + webmail are served. Mailu's
# front nginx renders `location ${WEB_ADMIN}` / `location ${WEB_WEBMAIL}`
# verbatim — without these set explicitly, the rendered nginx config
# has `location  {` (empty) and refuses to parse. Defaults match
# Mailu's docs: visit https://mail.<domain>/admin and /webmail.
WEB_ADMIN=/admin
WEB_WEBMAIL=/webmail

# Anti-virus scanning (ClamAV). Off by default — adds ~1GB RAM and
# slows inbound delivery noticeably. Flip to `true` if you start
# receiving real internet mail and want belt-and-braces over spam
# filtering.
ANTIVIRUS=none

# Pop-before-SMTP, fetchmail (pulls mail from external accounts),
# WebDAV calendars, etc. — all off; turn on as needed.
WEBDAV=none
FETCHMAIL=false

# ──────────────────────────────────────────────────────────────────
# Network — internal hostnames
# ──────────────────────────────────────────────────────────────────
# Mailu's images default to short names (`redis`, `admin`, etc.). We
# prefix everything with `mail-` to avoid colliding with the main
# compose's `redis` and `admin` services. Override the names here so
# each Mailu component can find its peers on the Docker network.

HOST_ADMIN=mail-admin
HOST_ANTISPAM=mail-antispam:11332
HOST_ANTISPAM_WEBUI=mail-antispam:11334
HOST_IMAP=mail-imap
HOST_LMTP=mail-imap:2525
HOST_SMTP=mail-smtp
HOST_AUTHSMTP=mail-smtp
HOST_WEBMAIL=mail-webmail
HOST_WEBDAV=mail-webdav:5232
HOST_REDIS=mail-redis
HOST_FRONT=mail-front

# ──────────────────────────────────────────────────────────────────
# Limits + policies
# ──────────────────────────────────────────────────────────────────

# Max single message size (MB). Keep in sync with the nginx
# `client_max_body_size` in nginx/mail-templates/mail.conf.template
# (set there to MESSAGE_SIZE_LIMIT * 1.1 to allow for MIME overhead).
MESSAGE_SIZE_LIMIT=50000000

# Per-user storage quota (bytes). 1 GiB is a reasonable starting
# point for an internal mailbox; raise per-user via the admin UI.
DEFAULT_QUOTA=1000000000

# Authentication rate limit (failed login attempts per minute per IP).
# Mailu's default of 10/minute is sensible — anything tighter starts
# locking out legitimate roaming clients.
AUTH_RATELIMIT=10/minute;1000/hour

# Outbound message rate limit per authenticated user (per day). Acts
# as a brake if a member account is compromised and used to send
# spam — bounces stop at this limit instead of getting our IP blocked.
MESSAGE_RATELIMIT=200/day

# Subnet treated as "internal" — Mailu skips spam-scoring + permits
# auth-less submission from these IPs. Default 192.168.203.0/24 is
# Mailu's internal Docker network; leave alone unless you fork the
# compose to change subnets.
SUBNET=192.168.203.0/24
SUBNET6=fc00::/7

# ──────────────────────────────────────────────────────────────────
# Letsencrypt / ACME — unused (we're in TLS_FLAVOR=cert), but Mailu
# warns at boot if the var is missing.
# ──────────────────────────────────────────────────────────────────
LETSENCRYPT_SHORTCHAIN=false
