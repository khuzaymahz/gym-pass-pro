#!/usr/bin/env bash
#
# Git pre-commit hook. Install with `make pre-commit-install`.
#
# Fast-path checks run before every commit so a typo / lint /
# uncompiled-Dart file never lands. Three rules:
#
#   1. No syntax-broken TS in the three Next surfaces — runs
#      `tsc --noEmit` on whichever surface has staged .ts/.tsx
#      files. Skipped surfaces don't run.
#   2. No syntax-broken Dart — `flutter analyze` on the entire
#      mobile/ tree when ANY `.dart` is staged. Mobile is one
#      Riverpod graph; a typo in feature/x can break feature/y
#      via the providers tree.
#   3. No backend Python file with a syntax error — `python -m
#      py_compile` on each staged .py. Cheap fast check.
#
# Lint-only failures (info / warning) don't block — the hook
# only fails on hard errors. Set `GYMPASS_PRECOMMIT_STRICT=1` to
# treat warnings as errors too.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

log()  { printf '\033[1;33m[pre-commit]\033[0m %s\n' "$*"; }
fail() { printf '\033[1;31m[pre-commit]\033[0m %s\n' "$*" >&2; exit 1; }

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [[ -z "$STAGED" ]]; then
  exit 0
fi

strict=${GYMPASS_PRECOMMIT_STRICT:-0}

# ---------- Backend Python --------------------------------------
PY=$(echo "$STAGED" | grep -E '^backend/.*\.py$' || true)
if [[ -n "$PY" ]]; then
  log "Python syntax check on $(wc -l <<<"$PY") staged file(s)…"
  for f in $PY; do
    python -m py_compile "$f" || fail "py_compile failed: $f"
  done
fi

# ---------- TS surfaces -----------------------------------------
for surface in admin gym-partner website; do
  HITS=$(echo "$STAGED" | grep -E "^${surface}/.*\.(ts|tsx)$" || true)
  if [[ -n "$HITS" ]]; then
    log "TypeScript check on $surface (tsc --noEmit)…"
    ( cd "$surface" && npx --no-install tsc --noEmit ) \
      || fail "tsc failed in $surface"
  fi
done

# ---------- Mobile Dart -----------------------------------------
DART=$(echo "$STAGED" | grep -E '^mobile/.*\.dart$' || true)
if [[ -n "$DART" ]]; then
  log "Dart analyze (flutter analyze on mobile/)…"
  flutter_flag="--no-fatal-warnings --no-fatal-infos"
  if [[ "$strict" == "1" ]]; then
    flutter_flag=""
  fi
  ( cd mobile && flutter analyze $flutter_flag ) \
    || fail "flutter analyze found errors"
fi

log "OK"
