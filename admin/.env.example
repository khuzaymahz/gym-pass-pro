# Admin dashboard — server-side env. Mirrors the keys validated by
# `admin/src/lib/env.server.ts` (and `admin/src/lib/env.ts` for the
# client-safe `PUBLIC_API_URL`).
#
# Most devs run admin inside docker-compose and don't need this file —
# the root `.env` is shared with the backend and admin reads the same
# vars. Keep this file in sync with `env.server.ts`'s Zod schema so a
# stand-alone `npm run dev` (outside docker) still boots.

# Server-side backend URL — used by Server Components / Server Actions.
# Inside docker this is `http://backend:8000` (service-name DNS); outside
# docker fall back to localhost.
API_BASE_URL=http://backend:8000

# Client-side public API URL — only used if a Client Component needs to
# fetch media or open SSE/WS directly. Reachable from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth signing key — `openssl rand -base64 32`. Must be >= 16 chars.
NEXTAUTH_SECRET=change-me-in-dev-only-32-chars-minimum
NEXTAUTH_URL=http://localhost:3001

# HMAC shared with the FastAPI admin-exchange endpoint. Must match the
# backend's `ADMIN_EXCHANGE_SECRET` exactly. `openssl rand -hex 32`.
ADMIN_EXCHANGE_SECRET=changeme-admin-exchange-secret

# Optional bootstrap admin (only consumed by `scripts/seed.py` at startup).
ADMIN_BOOTSTRAP_EMAIL=admin@gym-pass.net
ADMIN_BOOTSTRAP_PASSWORD=changeme-dev
