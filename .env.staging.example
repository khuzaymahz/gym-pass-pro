# Staging environment template — committed to git as a reference.
# The real file is `.env.staging` (gitignored), lives on the VM.
#
#   cp .env.staging.example .env.staging
#   nano .env.staging   # fill in the CHANGE_ME values
#
# Required values use `openssl rand -hex 32` (or `-base64 32`).

# ---- App ----
# Real staging — the backend's intent-named flags turn on
# production-shape behaviours (real OTP path, strict CORS, secret-
# strength enforcement, no demo seed) while SMS + payments stay
# mocked per CLAUDE.md §15. The OTP code is logged at INFO via
# structlog so testers can read it from `docker compose logs -f`.
APP_ENV=staging
LOG_LEVEL=INFO

# ---- Postgres ----
POSTGRES_USER=gympass
# `openssl rand -hex 32`
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASSWORD
POSTGRES_DB=gympass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- JWT ----
# `openssl rand -hex 32` — must be ≥32 chars or the staging-safety
# check refuses to boot.
JWT_SECRET=CHANGE_ME_STAGING_JWT_SECRET
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
JWT_SERVICE_TTL_SECONDS=300
JWT_ALGORITHM=HS256

# ---- SMS (mocked in staging — code logged via structlog) ----
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=GymPass

# ---- Payments (mocked in staging) ----
PAYMENT_PROVIDER=mock
PAYMENT_MOCK_DELAY_MS=1500

# ---- OAuth (Google) ----
# Optional in staging. Leave blank if you only test phone-OTP.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Domains (stg.gym-pass.net zone) ----
# These resolve into the nginx vhost templates via envsubst. The
# Cloudflare Origin Cert that covers *.gym-pass.net + apex covers
# every stg-* host below.
ADMIN_DOMAIN=stg-admin.gym-pass.net
API_DOMAIN=stg-api.gym-pass.net
PARTNER_DOMAIN=stg-partner.gym-pass.net
WEBSITE_DOMAIN=stg.gym-pass.net

# ---- CORS ----
# Backend's `cors_origins()` builds this from `${ADMIN_DOMAIN}` +
# `${PARTNER_DOMAIN}` automatically in staging/prod. Override here
# only if you need to whitelist a temporary tunnel.
# ALLOWED_CORS_ORIGINS=

# ---- Admin bootstrap ----
# Operator may keep a short password in staging — the safety
# check only requires ≥12 chars in `production`. Pick a real
# password anyway; staging is reachable from the internet.
ADMIN_BOOTSTRAP_EMAIL=admin@gym-pass.net
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_STAGING_BOOTSTRAP

# ---- NextAuth + service-token exchange ----
# Both >=32 chars. `openssl rand -hex 32`.
NEXTAUTH_SECRET=CHANGE_ME_STAGING_NEXTAUTH_SECRET
ADMIN_EXCHANGE_SECRET=CHANGE_ME_STAGING_EXCHANGE_SECRET

# ---- Media URL prefix (served by FastAPI's /media route) ----
MEDIA_URL_PREFIX=https://stg-api.gym-pass.net/media

# ---- Share base URL (mobile referral links) ----
SHARE_BASE_URL=https://stg.gym-pass.net
