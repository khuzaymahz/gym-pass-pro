<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ enforces its own splash API: windowBackground is ignored
  during the "cold start" window, only windowSplashScreenBackground +
  (optional) windowSplashScreenAnimatedIcon show. We deliberately omit the
  animated icon so the native window is a flat dark field — all branding
  lives in Flutter's SplashPage, which paints identically to this bg on
  its first frame so the handoff is invisible.
-->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/gp_ink</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/gp_ink</item>
    </style>
</resources>
