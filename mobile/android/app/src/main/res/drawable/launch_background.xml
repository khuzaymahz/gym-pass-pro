<?xml version="1.0" encoding="utf-8"?>
<!--
  Native launch window. Flat, day/night-aware fill — `@color/gp_launch_bg`
  resolves to the light off-white surface in `values/colors.xml` (OS-light
  mode) or the dark brand surface in `values-night/colors.xml` (OS-dark).
  The branded splash (wordmark + reveal animation + lime continuity dot)
  is owned by Flutter's SplashPage, which paints identically to this bg
  on its first frame so the handoff is invisible. This drawable just
  bridges the 300-800ms window between process-start and Flutter's
  first frame.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/gp_launch_bg" />
</layer-list>
