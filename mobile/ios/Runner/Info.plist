<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Gympass</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>gympass</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Location strings shown in the iOS permission prompt the first
	     time the Explore tab requests GPS. Apple rejects builds that
	     omit these strings, even if the app never actually requests
	     location, as long as the geolocator pod is linked. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>GymPass uses your location to centre the Explore map on you and show how far each gym is.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>GymPass uses your location to centre the Explore map on you and show how far each gym is.</string>
	<!-- Camera string is required by the mobile_scanner plugin which
	     links AVCaptureDevice. Apple rejects any build that links the
	     camera APIs without this key, even if the app never opens the
	     scanner. The string is shown the first time the member taps
	     "Scan to check in" — and again the first time a member taps
	     "Take a photo" on the bug-report attach-evidence sheet. -->
	<key>NSCameraUsageDescription</key>
	<string>GymPass uses the camera to scan QR codes at check-in and to capture photos when you report an issue.</string>
	<!-- Photo library string is required by image_picker for the
	     bug-report attach-evidence flow ("Choose from camera roll"). -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>GymPass needs access to your photos so you can attach a screenshot when reporting an issue.</string>
	<!-- Apple split the "saving to camera roll" permission out from
	     the read permission in iOS 11. We don't currently save to the
	     library, but image_picker links the AssetsLibrary framework, so
	     Apple rejects builds without this string. -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>GymPass may save edited photos back to your library when you attach them to a report.</string>
</dict>
</plist>
